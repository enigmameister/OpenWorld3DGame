  nodes:
  - id: start
    npcText: 'You must be from Fredo.

      Do you have the package?'
    options:
    - playerText: Yes, this is the package.
      nextNodeId: delivered
      debugEvent: Mission_FredoDelivery_DeliverToRalph
    - playerText: Not yet.
      nextNodeId: notyet
      debugEvent: 
    endAfterNpcLine: 0
  - id: delivered
    npcText: Good. I will let Fredo know the package arrived.
    options: []
    endAfterNpcLine: 1
  - id: notyet
    npcText: Then come back when you actually have it.
    options: []
    endAfterNpcLine: 1
  startNodeId: start
