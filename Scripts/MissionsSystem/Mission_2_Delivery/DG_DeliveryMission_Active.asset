  nodes:
  - id: start
    npcText: 'Why are you still here?

      Take that package to Ralph. He is waiting
      for it.'
    options:
    - playerText: I'm on it.
      nextNodeId: end
      debugEvent: 
    - playerText: Remind me what to do.
      nextNodeId: remind
      debugEvent: 
    endAfterNpcLine: 1
  - id: remind
    npcText: 'Find Ralph and hand him the package.

      After that, come back to
      me for your payment.'
    options:
    - playerText: Got it.
      nextNodeId: end
      debugEvent: 
    endAfterNpcLine: 1
  - id: end
    npcText: Don't keep him waiting.
    options:
    - playerText: Got it.
      nextNodeId: end
      debugEvent: 
    - playerText: Remind me what to do.
      nextNodeId: remind
      debugEvent: 
    endAfterNpcLine: 1
  startNodeId: start
