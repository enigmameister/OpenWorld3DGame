  m_Script: {fileID: 11500000, guid: b957bb3dd05460a4db7af93ce53c5bfb, type: 3}
  m_Name: Bank_ID_GATE
  m_EditorClassIdentifier: Assembly-CSharp::DialogueGraph
  nodes:
  - id: start
    npcText: I would like to have my ID card please.
    options:
    - playerText: Here.
      nextNodeId: '@event'
      debugEvent: CHECK_ID
    - playerText: Back
      nextNodeId: graph:Start/start
      debugEvent: 
    - playerText: I don't think I have it, I have to go out
      nextNodeId: '@end'
      debugEvent: 
    endAfterNpcLine: 0
  - id: NO_ID
    npcText: I don't see an ID card. First, get one at the city hall.
    options:
    - playerText: Back
      nextNodeId: graph:Start/start
      debugEvent: 
    - playerText: I'm out
      nextNodeId: '@end'
      debugEvent: 
    endAfterNpcLine: 0
  startNodeId: start
